#!/bin/bash
# experiments/019-simb-multimodal/scripts/gh_cgt_multitask_array.slurm
# GilaHyper SINGLE-GPU job-array launcher for the Fig-3 expression sniff-sweep (SIMB 2026).
# Maps $SLURM_ARRAY_TASK_ID -> the gh_expr_grid_<NNN> config generated by
# generate_expr_grid.py, and runs it with PLAIN python (devices=1, strategy=auto, NO DDP,
# NO torchrun). The %4 throttle keeps exactly 4 concurrent tasks -> 4 GPUs busy.
#
#   # regenerate configs + manifest first (from repo root):
#   python experiments/019-simb-multimodal/scripts/generate_expr_grid.py
#   # then launch the full array (N printed by the generator; 288 runs -> 0-287):
#   sbatch --array=0-287%4 experiments/019-simb-multimodal/scripts/gh_cgt_multitask_array.slurm
#
# --array is passed on the command line (not hard-coded) so the same script serves any N.
#SBATCH -p main
#SBATCH --mem=120g
#SBATCH -N 1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --gres=gpu:1
#SBATCH --job-name=019-expr-grid
#SBATCH --time=2:00:00
#SBATCH --mail-user=mjvolk3@illinois.edu
#SBATCH --mail-type=END,FAIL
#SBATCH --output=/home/michaelvolk/Documents/projects/torchcell/experiments/019-simb-multimodal/slurm/output/%x_%A_%a.out
#SBATCH --error=/home/michaelvolk/Documents/projects/torchcell/experiments/019-simb-multimodal/slurm/output/%x_%A_%a.out

# Zero-pad the array task id to the 3-digit config name (gh_expr_grid_000 ...).
CONFIG_NAME=$(printf "gh_expr_grid_%03d" "$SLURM_ARRAY_TASK_ID")
echo "job=$SLURM_ARRAY_JOB_ID task=$SLURM_ARRAY_TASK_ID config=$CONFIG_NAME host=$(hostname)"

# Change to the experiments directory (matches the 019 GilaHyper convention).
cd /home/michaelvolk/Documents/projects/torchcell/experiments || exit 1

# Activate conda (no container on GilaHyper). Source conda.sh (NOT bin/activate).
source ~/miniconda3/etc/profile.d/conda.sh
conda activate torchcell

# Add project to PYTHONPATH.
export PYTHONPATH="/home/michaelvolk/Documents/projects/torchcell:$PYTHONPATH"

# CUDA / runtime knobs.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export CUDA_LAUNCH_BLOCKING=0
export TORCH_USE_CUDA_DSA=0
export PYTHONUNBUFFERED=1
export PYTHONWARNINGS="ignore"  # Suppress SWIG DeprecationWarnings
export WANDB__SERVICE_WAIT=600

# num_workers from the SLURM CPU allocation (reserve 2 for overhead).
export NUM_WORKERS=$((SLURM_CPUS_PER_TASK - 2))

# Plain python — single GPU, no torchrun, no DDP.
python \
  /home/michaelvolk/Documents/projects/torchcell/experiments/019-simb-multimodal/scripts/train_cgt_multitask.py \
  --config-name "$CONFIG_NAME" \
  data_module.num_workers=$NUM_WORKERS
