# LaTeX build intermediates (paper/nature-biotech) -- regenerated on every build
# (tectonic/latexmk), machine-specific, never committed. The output PDFs
# (submission/editing/twocolumn.pdf) and figures/*.pdf stay tracked; only the
# intermediates below are ignored.
paper/nature-biotech/*.aux
paper/nature-biotech/*.bbl
paper/nature-biotech/*.blg
paper/nature-biotech/*.fdb_latexmk
paper/nature-biotech/*.fls
paper/nature-biotech/*.synctex.gz
paper/nature-biotech/*.out
paper/nature-biotech/*.log
paper/nature-biotech/*.toc
paper/nature-biotech/*.lof
paper/nature-biotech/*.lot
paper/nature-biotech/*.bcf
paper/nature-biotech/*.run.xml
