          </mxGeometry>
        </mxCell>
        <mxCell id="collabel" value="blue dashed = 88 mm single-column width (347 units)" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#1971C2;" vertex="1" parent="1">
          <mxGeometry x="350" y="746" width="309" height="18" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Copy the RED box into a figure as a sizing guide and design WITHIN it. Panel / label text 5–7 pt at final size; line weights ≥ 0.25 pt.&#10;Hide or delete this guide before exporting the real figure (File → Export as → PDF, crop to drawing, no page background)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;spacingLeft=2;" vertex="1" parent="1">
          <mxGeometry x="150" y="772" width="709" height="70" as="geometry" />
        </mxCell>
